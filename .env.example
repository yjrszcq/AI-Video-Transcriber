# OpenAI API Configuration
# You can leave this empty and configure the API key in the web UI.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (for proxy or alternative endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Custom OpenAI Model
OPENAI_OPTIMIZE_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Server Configuration (Optional)
# PORT controls the published port mapping in docker-compose.
PORT=8000

# Whisper Model Configuration (Optional)
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base

# Set to true to overwrite matching runtime cache files from preloaded image models
REPAIR_PRELOADED_HF_CACHE=false

# Local upload size limit in MB (optional; Docker Compose passes this through)
UPLOAD_MAX_MB=200

# SSE heartbeat interval in seconds (keeps long-running tasks connected)
SSE_HEARTBEAT_SECONDS=10
